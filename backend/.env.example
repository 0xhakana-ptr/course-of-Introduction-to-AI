APP_VERSION=0.2.0
LOG_LEVEL=INFO

# Workspace / command execution
COMMAND_TIMEOUT_SECONDS=15
RUN_REPAIR_MAX_ATTEMPTS=1
CONVERSATION_HISTORY_MAX_MESSAGES=20
CONVERSATION_CONTEXT_RECENT_MESSAGES=8
CONVERSATION_SUMMARY_MAX_CHARS=1200
CHAT_CONTEXT_MAX_CHARS=6000
CONVERSATION_SESSION_TTL_SECONDS=604800
CONVERSATION_MAX_PERSISTED_SESSIONS=200
CONVERSATION_CLEANUP_INTERVAL_SECONDS=60

# OpenAI-compatible example:
# LLM_BASE_URL should normally be the provider's API root, such as .../v1.
# The backend will append /chat/completions automatically unless
# LLM_CHAT_COMPLETIONS_URL is set explicitly.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_PROVIDER_PROFILE=openai
#
# LongCat OpenAI-compatible example:
# LongCat's documented API root currently contains /openai/v1; this is
# provider-specific, not a general requirement for every OpenAI-compatible URL.
# LLM_BASE_URL=https://api.longcat.chat/openai/v1
# LLM_PROVIDER_PROFILE=openai
# LLM_MODEL=LongCat-Flash-Thinking-2601
# If you use a slow thinking model, you may want a shorter primary timeout
# plus a fast fallback model:
# LLM_TIMEOUT_SECONDS=20
# LLM_FALLBACK_MODEL=LongCat-Flash-Chat
# LLM_FALLBACK_TIMEOUT_SECONDS=30
#
# MiniMax example:
# LLM_BASE_URL=https://api.minimaxi.com/v1
# LLM_PROVIDER_PROFILE=minimax
# LLM_MODEL=MiniMax-M2.7
#
# If a provider needs a non-standard chat completions endpoint, you can
# override it directly:
# LLM_CHAT_COMPLETIONS_URL=https://your-provider.example.com/custom/chat/completions
LLM_BASE_URL=
LLM_CHAT_COMPLETIONS_URL=
LLM_PROVIDER_PROFILE=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_CHAT_COMPLETIONS_URL=
LLM_FALLBACK_PROVIDER_PROFILE=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_TIMEOUT_SECONDS=30
LLM_SYSTEM_PROMPT=你是一个运行在 Live2D 桌宠中的 AI 伙伴，也是前台看板娘。请优先使用自然、清楚、偏口语化的中文回答，并保留轻微角色感。普通聊天时先直接回应用户；涉及代码或工具任务时，只说明你已经确认的事实，不要假装执行过并未执行的操作。除非用户明确要求查看详细日志，否则不要把冗长的原始报错、堆栈或工程噪声直接倾倒给用户，优先给出简短总结和下一步建议。
