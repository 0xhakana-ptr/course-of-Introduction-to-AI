# 后端环境变量
# 复制此文件为 .env：  cp .env.example .env

APP_VERSION=0.2.0
LOG_LEVEL=INFO


# LLM 配置（必填）
# 后端只要求 OpenAI-compatible 接口，不限定供应商。
# LLM_BASE_URL 填写 API root，后端会自动拼接 /chat/completions。
# 如果供应商的聊天端点不是标准路径，可额外设置 LLM_CHAT_COMPLETIONS_URL。
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_PROVIDER_PROFILE=            # openai / minimax（可选，留空自动探测）
LLM_CHAT_COMPLETIONS_URL=        # 通常不需要，除非供应商端点非标准
LLM_TIMEOUT_SECONDS=30


# 主模型故障时的回落模型（可选）
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_PROVIDER_PROFILE=
LLM_FALLBACK_CHAT_COMPLETIONS_URL=
LLM_FALLBACK_TIMEOUT_SECONDS=30

# 自定义系统提示词（可选，不填则使用 config.py 内置默认值）
# LLM_SYSTEM_PROMPT=你是一个运行在 Live2D 桌宠中的 AI 伙伴，也是前台看板娘。请优先使用自然、清楚、偏口语化的中文回答，并保留轻微角色感。普通聊天时先直接回应用户；涉及代码或工具任务时，只说明你已经确认的事实，不要假装执行过并未执行的操作。


# 工作区与命令执行
COMMAND_TIMEOUT_SECONDS=15
RUN_REPAIR_MAX_ATTEMPTS=1

# 会话与记忆
CONVERSATION_HISTORY_MAX_MESSAGES=20
CONVERSATION_CONTEXT_RECENT_MESSAGES=8
CONVERSATION_SUMMARY_MAX_CHARS=1200
CHAT_CONTEXT_MAX_CHARS=6000
CHAT_EXTERNAL_CONTEXT_MAX_CHARS=2000
CONVERSATION_RECENT_MESSAGE_MAX_CHARS=800
CONVERSATION_SESSION_TTL_SECONDS=604800        # 7 天
CONVERSATION_MAX_PERSISTED_SESSIONS=200
CONVERSATION_CLEANUP_INTERVAL_SECONDS=60


# 桌面导出（默认关闭）
# 开启后允许后端将文件写入指定目录。不建议直接指向真实桌面。
DESKTOP_EXPORT_ENABLED=false
DESKTOP_EXPORT_DIR=


# 真实项目访问（默认关闭）
# 配置后文件工具可读取/写入真实项目目录。
# 敏感路径（.git .env node_modules 等）会被安全层拦截。
PROJECT_WRITE_ENABLED=false
PROJECT_ROOT=


# 视觉截图识别（默认开启）
# 运行时可能偶尔卡顿，如果不需要可以关闭。
VISION_ENABLED=true
VISION_INTERVAL_SECONDS=60               # 截图间隔（秒）
VISION_CONFIDENCE_THRESHOLD=0.4          # 检测置信度阈值
VISION_QUIP_COOLDOWN_SECONDS=120         # 两次视觉吐槽的最小间隔（秒）
VISION_MAX_CACHED_SCREENSHOTS=10         # 最大缓存截图数
